#!/bin/bash
# Pre-commit hook: 强制验证 CHECKLIST.md 已完成
# 安装: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

CHECKLIST="CHECKLIST.md"
ERRORS=0
LAST_COMMIT=$(git rev-parse HEAD 2>/dev/null)

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Pre-Commit Verification"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# 1. CHECKLIST.md 必须在暂存区
if ! git diff --cached --name-only | grep -q "^${CHECKLIST}$"; then
    echo "❌ CHECKLIST.md 未在暂存区！"
    echo "   请完成检查后: git add CHECKLIST.md"
    ERRORS=$((ERRORS + 1))
fi

# 2. 所有 [ ] 必须改为 [x]
UNCHECKED=$(git show :${CHECKLIST} 2>/dev/null | grep -c '^\- \[ \]')
if [ "$UNCHECKED" -gt 0 ]; then
    echo "❌ CHECKLIST.md 有 ${UNCHECKED} 项未完成！"
    git show :${CHECKLIST} 2>/dev/null | grep -n '^\- \[ \]'
    ERRORS=$((ERRORS + 1))
fi

# 3. 时间戳必须更新（防止复用上次的检查结果）
if [ -n "$LAST_COMMIT" ]; then
    OLD_TS=$(git show "${LAST_COMMIT}:${CHECKLIST}" 2>/dev/null | grep "Last Verification:" | head -1)
    NEW_TS=$(git show ":${CHECKLIST}" 2>/dev/null | grep "Last Verification:" | head -1)
    if [ "$OLD_TS" = "$NEW_TS" ]; then
        echo "❌ CHECKLIST.md 时间戳未更新！"
        echo "   上次: $OLD_TS"
        echo "   本次: $NEW_TS"
        echo "   请完成本轮检查并更新 Last Verification 时间戳"
        ERRORS=$((ERRORS + 1))
    fi
fi

# 4. 检查是否有未暂存的 .py/.tsx 修改（说明改了代码但没走检查流程）
UNSTAGED=$(git diff --name-only | grep -E '\\.(py|tsx)$' | head -5)
if [ -n "$UNSTAGED" ]; then
    echo "⚠️  有未暂存的代码修改，可能未经验证:"
    echo "$UNSTAGED"
    echo "   建议: git add 这些文件并重新检查"
fi

# 5. 检查代码变更是否走 pipeline（警告，不阻止）
STAGED_CODE=$(git diff --cached --name-only | grep -E "^(backtest/|experts/|factors/|tests/|dashboard/src/|scripts/(?!pre-commit))" | head -1)
STAGED_PLAN=$(git diff --cached --name-only | grep "^.hermes/plans/" | head -1)
if [ -n "$STAGED_CODE" ] && [ -z "$STAGED_PLAN" ]; then
    echo "⚠️  代码变更但未发现 pipeline artifact (.hermes/plans/)"
    echo "   工作流: Architect → change_plan → 分派 → 审查 → DevOps"
    echo "   这是警告，不阻止提交。但如果只是跳过流程，用户可能会纠正你。"
fi

echo ""
if [ "$ERRORS" -eq 0 ]; then
    echo "✅ 所有检查通过，允许提交"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
else
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "❌ ${ERRORS} 项检查失败，提交被阻止"
    echo "   完成 CHECKLIST.md 并 git add 后重试"
    exit 1
fi
