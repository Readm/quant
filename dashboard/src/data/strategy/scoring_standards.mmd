graph LR
    subgraph Composite["综合评分公式"]
        Sortino["Sortino × 0.22"]
        Calmar["Calmar × 0.18"]
        IR["IR × 0.18"]
        Drawdown["最大回撤 × 0.18"]
        AlphaScaled["Alpha缩放 × 0.24<br/>= max(0, min(100, α×5))"]
    end

    Composite --> Sum["= 综合分(0~100)"]

    Sum --> TradeAdj["交易可靠性调整"]
    TradeAdj --> |"≥20笔 +5"| A1
    TradeAdj --> |"≥10笔 +2"| A2
    TradeAdj --> |"≥5笔 +1"| A3
    TradeAdj --> |"≤2笔 ×0.5 且降级CONDITIONAL"| A4

    Sum --> PBO["PBO洗牌检验 ✨Iter11<br/>洗牌日收益300次"]
    PBO --> |"≥50%洗牌胜出 硬拒"| Reject
    PBO --> |"≥30% ×0.85"| Discount
    PBO --> |"<30% 可信"| Accept

    Sum --> AntiMono["反垄断加分 ✨Iter11<br/>按策略名关键词判断"]
    AntiMono --> |"Top-3全趋势且当前均值回归 +3"| MR

    Sum --> Diversity["多样性奖励"]
    Diversity --> |"4轮未出现+2, 8轮+5, 长期+8"| D

    Sum --> Decision["决策阈值"]
    Decision --> |"≥45 ACCEPT"| Accept
    Decision --> |"≥25 CONDITIONAL"| Wait
    Decision --> |"<25 REJECT"| Reject

    style Accept fill:#f0f0f0,stroke:#666,stroke-width:1px
    style Wait fill:#f0f0f0,stroke:#666,stroke-width:1px
    style Reject fill:#f0f0f0,stroke:#666,stroke-width:1px
